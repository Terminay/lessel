# ── lessel Configuration ──────────────────────────────────────────────

# Discord Bot Token (required for Discord listener)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated list of Discord channel IDs to monitor (optional)
# Leave empty to monitor all accessible channels
DISCORD_ALLOWED_CHANNELS=channel_id_1,channel_id_2

# Comma-separated list of Discord user IDs to ignore (optional)
DISCORD_IGNORE_USERS=user_id_1,user_id_2

# lessel API Server Port (default: 3100)
LESSEL_API_PORT=3100

# Path to lessel config JSON (default: ./lessel.config.json)
LESSEL_CONFIG=./lessel.config.json

# Path to SQLite database file (default: ./data/lessel.db)
LESSEL_DB_PATH=./data/lessel.db