# ⚠️  SECURITY WARNING ⚠️
# Never commit real API keys, tokens, or secrets to version control.
# Copy this file to .env and fill in real values.
# .env is gitignored — do not remove it from .gitignore.

# ── Discord ─────────────────────────────────────────────────────
# Discord Bot Token (required for Discord listener)
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated list of Discord channel IDs to monitor (optional)
# Leave empty to monitor all accessible channels
DISCORD_ALLOWED_CHANNELS=channel_id_1,channel_id_2

# Comma-separated list of Discord user IDs to ignore (optional)
DISCORD_IGNORE_USERS=user_id_1,user_id_2

# ── Slack ───────────────────────────────────────────────────────
# Slack Bot Token (required for Slack listener)
# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=your_slack_bot_token_here

# Slack App-Level Token (required for Socket Mode)
# Generate from your Slack app's Basic Information page
SLACK_APP_TOKEN=your_slack_app_token_here

# Comma-separated list of Slack channel IDs to monitor (optional)
SLACK_ALLOWED_CHANNELS=channel_id_1,channel_id_2

# Comma-separated list of Slack user IDs to ignore (optional)
SLACK_IGNORE_USERS=user_id_1,user_id_2

# ── WhatsApp ────────────────────────────────────────────────────
# WhatsApp phone number (required for WhatsApp listener)
# Format: 1234567890 (without +)
WHATSAPP_PHONE=your_whatsapp_phone_number

# Path to WhatsApp session directory (optional, default: ./whatsapp-session)
WHATSAPP_SESSION=./whatsapp-session

# Comma-separated list of phone numbers to allow (optional)
WHATSAPP_ALLOWED_NUMBERS=number_1,number_2

# ── lessel Configuration ────────────────────────────────────────
# lessel API Server Port (default: 3100)
LESSEL_API_PORT=3100

# Path to lessel config JSON (default: ./lessel.config.json)
LESSEL_CONFIG=./lessel.config.json

# Path to SQLite database file (default: ./data/lessel.db)
LESSEL_DB_PATH=./data/lessel.db

# ── Built-in Plugins ────────────────────────────────────────────
# Webhook: Comma-separated list of URLs to forward matched messages
LESSEL_WEBHOOK_URL=https://hooks.example.com/endpoint

# Webhook: Only forward messages matching this schema name (optional)
LESSEL_WEBHOOK_SCHEMA=catch-all-discord

# Rate Limiter: Window in milliseconds (default: 5000)
LESSEL_RATE_LIMIT_WINDOW=5000

# Rate Limiter: Max executions per window (default: 5)
LESSEL_RATE_LIMIT_MAX=5